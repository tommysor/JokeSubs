{
    "chat.tools.terminal.autoApprove": {
        "aspire run": true,
        "dotnet build": true,
        "dotnet list": true,
        "dotnet restore": true,
        "dotnet test": true,
        "dotnet package search": true,
        "npm run build": true
    },
    "chat.tools.urls.autoApprove": {
        "https://code.visualstudio.com": true,
        "https://github.com/microsoft/*": true,
        "https://github.com/dotnet/*": true,
        "https://learn.microsoft.com": true,
        "https://aspire.dev": true,
        "https://www.nuget.org": true,
        "https://xunit.net": true
    },
    "dotnetAcquisitionExtension.existingDotnetPath": [
        {
            "extensionId": "ms-dotnettools.csdevkit",
            "path": "/home/vscode/.dotnet-csharp-host/dotnet"
        },
        {
            "extensionId": "ms-dotnettools.csharp",
            "path": "/home/vscode/.dotnet-csharp-host/dotnet"
        }
    ],
    "dotnetAcquisitionExtension.allowInvalidPaths": true
}